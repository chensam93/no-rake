#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if command -v gitleaks >/dev/null 2>&1; then
  echo "Running gitleaks on staged changes..."
  gitleaks protect --staged --redact --config .gitleaks.toml
  exit $?
fi

echo "gitleaks not found on PATH; running lightweight staged secret scan."

staged_added_lines="$(git diff --cached --unified=0 --no-color -- . ':(exclude).githooks/pre-commit' ':(exclude).gitleaks.toml' ':(exclude).github/workflows' | awk '/^\+[^+]/ { sub(/^\+/, ""); print }')"

if [ -z "$staged_added_lines" ]; then
  exit 0
fi

pattern='AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|-----BEGIN (RSA|OPENSSH|EC|DSA) PRIVATE KEY-----|aws_access_key_id|aws_secret_access_key|api[_-]?key[[:space:]]*[:=]|client[_-]?secret[[:space:]]*[:=]|password[[:space:]]*[:=]|token[[:space:]]*[:=]'

if printf '%s\n' "$staged_added_lines" | grep -E -i "$pattern" >/dev/null; then
  echo "Potential secret detected in staged changes."
  echo "Commit blocked. Review with: git diff --cached"
  echo "If this is a false positive, redact the value or adjust .gitleaks.toml."
  exit 1
fi

exit 0
